# Groq API (required for recommendation engine — Phase 4+)
GROQ_API_KEY=your_groq_api_key_here

# Groq models
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=2048

# Budget tier thresholds (INR for two people)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# Recommendation pipeline limits
MAX_CANDIDATES=20
TOP_N=5

# Data cache path (relative to project root)
DATA_CACHE_PATH=data/processed/restaurants.parquet

# Hugging Face dataset
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
